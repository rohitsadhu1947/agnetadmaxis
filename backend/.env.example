TELEGRAM_BOT_TOKEN=your_adm_bot_token_here
ANTHROPIC_API_KEY=your_key_here
API_BASE_URL=http://localhost:8000

# Agent Telegram Bot (separate bot for agents)
AGENT_TELEGRAM_BOT_TOKEN=your_agent_bot_token_here

# Feature Flags
ENABLE_AGENT_BOT=true
ENABLE_AI_FEATURES=true

# Database — choose one:
# Local development (SQLite, default):
DATABASE_URL=sqlite:///./adm_platform.db
# Production (Neon PostgreSQL — set this in Railway env vars):
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
